# API base (include /api)
VITE_API_URL=http://localhost:8080/api

# Optional: Socket.IO origin if different from API host
VITE_SOCKET_URL=http://localhost:8080

# Firebase (client) — same project as server Admin SDK
# Copy from Firebase Console → Project settings → Your apps → Web app (SDK snippet).
# Required: apiKey, projectId, appId, messagingSenderId.
# authDomain / storageBucket optional: defaults to {projectId}.firebaseapp.com and {projectId}.appspot.com
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
