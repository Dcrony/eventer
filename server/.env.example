# Server
PORT=8080
MONGO_URI=mongodb://127.0.0.1:27017/eventer
JWT_SECRET=change-me-to-a-long-random-string
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8080
# Optional extra origins (comma-separated). Merged with built-in dev URLs (localhost + 127.0.0.1 on 5173/4173).
# ALLOWED_ORIGINS=https://your-app.vercel.app

# Paystack (use PAYSTACK_SECRET_KEY; PAYSTACK_SECRET is legacy fallback)
PAYSTACK_SECRET_KEY=
PAYSTACK_CALLBACK=http://localhost:8080/api/payment/verify

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM=TickiSpot <onboarding@yourdomain.com>

# Firebase Admin (verify Google ID tokens from the client)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
