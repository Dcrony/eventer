# Cloudinary (user-uploaded images: events, profile, cover — not used for live/streaming video)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=


ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
ZOOM_OAUTH_REDIRECT_URI=


# Server
PORT=8080
MONGO_URI=mongodb://127.0.0.1:27017/eventer
JWT_SECRET=change-me-to-a-long-random-string
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8080
# Optional extra origins (comma-separated). Merged with built-in dev URLs (localhost + 127.0.0.1 on 5173/4173).
# ALLOWED_ORIGINS=https://your-app.vercel.app

# Paystack (use PAYSTACK_SECRET_KEY; PAYSTACK_SECRET is legacy fallback)
PAYSTACK_SECRET_KEY=
PAYSTACK_CALLBACK=http://localhost:8080/api/payment/verify
BILLING_VERIFY_URL=http://localhost:8080/api/billing/verify

# Resend (transactional email)
RESEND_API_KEY=
RESEND_FROM=TickiSpot <onboarding@yourdomain.com>

# Firebase Admin (verify Google ID tokens from the client)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Alternative: full service account JSON (raw JSON string or base64-encoded JSON)
# FIREBASE_SERVICE_ACCOUNT_JSON=
